# URL de ton API
PORT=3000

# Secret pour signer les JWT (generer une valeur unique, ne jamais committer le vrai secret)
JWT_SECRET=replace-with-a-long-random-secret

# Connexion PostgreSQL (doit correspondre a docker/docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_NAME=mmorpgdb
